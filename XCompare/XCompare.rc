            MENUITEM "Visual Studio 200&5",         ID_VIEW_APPLOOK_VS_2005
            MENUITEM "Visual Studio 200&8",         ID_VIEW_APPLOOK_VS_2008
            POPUP "Office 200&7"
            BEGIN
                MENUITEM "&Modrï¿½ styl",                 ID_VIEW_APPLOOK_OFF_2007_BLUE
                MENUITEM "ï¿½&ernï¿½ styl",                 ID_VIEW_APPLOOK_OFF_2007_BLACK
