    BEGIN
        BLOCK "000904b0"
        BEGIN
            VALUE "CompanyName", "javlik"
            VALUE "FileDescription", "XCompare"
            VALUE "FileVersion", "2.0.1.2"
            VALUE "InternalName", "XCompare.exe"
            VALUE "LegalCopyright", "© 2018 Jirí Havlík, License CC BY-SA 4.0"
            VALUE "OriginalFilename", "XCompare.exe"
            VALUE "ProductName", "XCompare (Cross comparison tool)"
            VALUE "ProductVersion", "2.0.1.2"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x9, 1200
    END
END


